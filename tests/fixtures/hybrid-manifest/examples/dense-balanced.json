{
  "version": 1,
  "profile": "dense-balanced",
  "strict": true,
  "npu_pattern": ["FP16_STANDARD", "INT8_STANDARD"],
  "routes": [
    {
      "name": "cpu-experts",
      "match": "\\.ffn_(up|down|gate|gate_up)_exps\\.weight$",
      "target": "cpu"
    },
    {
      "name": "default-dense",
      "match": "^blk\\.[0-9]+\\.(attn|ffn)_",
      "target": "default",
      "pipeline": "FP16_STANDARD",
      "quant_allow": ["f16", "q8_0"],
      "shape": {
        "n_divisible_by": 32
      }
    }
  ]
}
