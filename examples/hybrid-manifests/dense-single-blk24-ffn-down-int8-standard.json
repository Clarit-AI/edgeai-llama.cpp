{
  "version": 1,
  "profile": "dense-balanced",
  "strict": true,
  "npu_pattern": ["FP16_STANDARD", "INT8_STANDARD"],
  "routes": [
    {
      "name": "cpu-experts",
      "match": "\\.ffn_(up|down|gate|gate_up)_exps\\.weight$",
      "target": "cpu"
    },
    {
      "name": "single-blk24-ffn-down-int8-standard",
      "match": "^blk\\.24\\.ffn_down\\.",
      "target": "default",
      "pipeline": "INT8_STANDARD",
      "quant_allow": ["f16", "q8_0"],
      "shape": {
        "k_divisible_by": 32,
        "n_divisible_by": 32
      }
    }
  ]
}
